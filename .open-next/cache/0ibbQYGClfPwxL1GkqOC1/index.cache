/_next/static/chunks/3-9v5llyj1vf9.js\" async=\"\"></script><title>Belmont Apartments — Refined Urban Living</title><meta name=\"description\" content=\"Experience luxury apartment living in the heart of the city. Belmont Apartments offers elegant residences with world-class amenities.\"/><script src=\"/_next/static/chunks/0cz1d0mv5g_q7.js\" noModule=\"\"></script></head><body><div hidden=\"\"><!--$--><!--/$--></div><header class=\"fixed top-0 left-0 right-0 z-50 transition-all duration-500 bg-transparent\"><nav class=\"max-w-7xl mx-auto px-6 lg:px-12 flex items-center justify-between h-20\"><a class=\"font-display text-2xl font-light tracking-wide text-charcoal\" href=\"/\">Belmont</a><ul class=\"hidden md:flex items-center gap-10\"><li><a class=\"text-xs tracking-widest uppercase font-sans text-warm-gray hover:text-charcoal transition-colors duration-200\" href=\"/rooms\">Residences</a></li><li><a class=\"text-xs tracking-widest uppercase font-sans text-warm-gray hover:text-charcoal transition-colors duration-200\" href=\"/rooms#amenities\">Amenities</a></li><li><a class=\"text-xs tracking-widest uppercase font-sans text-warm-gray hover:text-charcoal transition-colors duration-200\" href=\"/about\">About</a></li><li><a class=\"text-xs tracking-widest uppercase font-sans text-warm-gray hover:text-charcoal transition-colors duration-200\" href=\"/contact\">Contact</a></li></ul><a class=\"hidden md:inline-block btn-primary text-xs py-2.5 px-6\" href=\"/booking\">Book Now</a><button class=\"md:hidden flex flex-col gap-1.5 p-2\" aria-label=\"Toggle menu\"><span class=\"block w-6 h-px bg-charcoal transition-all \"></span><span class=\"block w-6 h-px bg-charcoal transition-all \"></span><span class=\"block w-6 h-px bg-charcoal transition-all \"></span></button></nav></header><main><section class=\"relative min-h-screen flex flex-col justify-end overflow-hidden\"><div class=\"absolute inset-0\"><img alt=\"Belmont Apartments lobby\" decoding=\"async\" data-nimg=\"fill\" class=\"object-cover\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=%2Fimages%2Fbelmont2.jpg&amp;w=640&amp;q=75 640w, /_next/image?url=%2Fimages%2Fbelmont2.jpg&amp;w=750&amp;q=75 750w, /_next/image?url=%2Fimages%2Fbelmont2.jpg&amp;w=828&amp;q=75 828w, /_next/image?url=%2Fimages%2Fbelmont2.jpg&amp;w=1080&amp;q=75 1080w, /_next/image?url=%2Fimages%2Fbelmont2.jpg&amp;w=1200&amp;q=75 1200w, /_next/image?url=%2Fimages%2Fbelmont2.jpg&amp;w=1920&amp;q=75 1920w, /_next/image?url=%2Fimages%2Fbelmont2.jpg&amp;w=2048&amp;q=75 2048w, /_next/image?url=%2Fimages%2Fbelmont2.jpg&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=%2Fimages%2Fbelmont2.jpg&amp;w=3840&amp;q=75\"/><div class=\"absolute inset-0 bg-gradient-to-t from-charcoal/80 via-charcoal/20 to-transparent\"></div></div><div class=\"relative z-10 max-w-7xl mx-auto px-6 lg:px-12 pb-24 pt-40 w-full\"><p class=\"section-label text-gold-light mb-6\">Akim Oda · Ghana</p><h1 class=\"font-display font-light text-cream text-[clamp(3.5rem,10vw,9rem)] leading-none mb-8 max-w-3xl\">Live Beyond<br/><span class=\"italic\">Ordinary</span></h1><p class=\"text-cream/70 font-sans text-base max-w-sm mb-10 leading-relaxed\">Curated residences where architectural precision meets the warmth of home. Belmont is not simply an address it is a way of living.</p><div class=\"flex flex-wrap gap-4\"><a class=\"btn-outline-light text-xs\" href=\"/rooms\">View Residences</a><a class=\"btn-primary text-xs\" href=\"/booking\">Book</a></div></div><div class=\"absolute bottom-10 right-12 hidden lg:flex flex-col items-center gap-3\"><span class=\"text-cream/40 text-xs tracking-widest uppercase rotate-90 mb-4\">Scroll</span><div class=\"w-px h-16 bg-cream/20 relative overflow-hidden\"><div class=\"w-full h-1/2 bg-gold animate-bounce\"></div></div></div></section><section class=\"bg-charcoal text-cream\"><div class=\"max-w-7xl mx-auto px-6 lg:px-12 py-12 grid grid-cols-2 md:grid-cols-4 gap-8\"><div class=\"text-center\"><p class=\"font-display text-5xl font-light text-gold\">2</p><p class=\"text-xs tracking-widest uppercase text-warm-gray mt-2 font-sans\">Residences</p></div><div class=\"text-center\"><p class=\"font-display text-5xl font-light text-gold\">8</p><p class=\"text-xs tracking-widest uppercase text-warm-gray mt-2 font-sans\">Apartments</p></div><div class=\"text-center\"><p class=\"font-display text-5xl font-light text-gold\">5★</p><p class=\"text-xs tracking-widest uppercase text-warm-gray mt-2 font-sans\">Average Rating</p></div><div class=\"text-center\"><p class=\"font-display text-5xl font-light text-gold\">2026</p><p class=\"text-xs tracking-widest uppercase text-warm-gray mt-2 font-sans\">Completed</p></div></div></section><section class=\"max-w-7xl mx-auto px-6 lg:px-12 py-32\"><div class=\"grid grid-cols-1 lg:grid-cols-2 gap-16 items-center\"><div><p class=\"section-label\">Our Story</p><h2 class=\"font-display text-[clamp(2.5rem,5vw,4.5rem)] font-light leading-tight mb-8 text-charcoal\">Where  Comfort <br/>Meets <span class=\"italic\">Elegance</span></h2><p class=\"text-warm-gray font-sans leading-relaxed mb-6\">Belmont Apartments was created to provide a peaceful and comfortable stay in the heart of Akim Oda. Every space has been thoughtfully designed to combine modern convenience with a warm, welcoming atmosphere.</p><p class=\"text-warm-gray font-sans leading-relaxed mb-10\">From our fully private apartments and beautifully maintained gardens to our modern amenities and relaxing surroundings, Belmont offers a place where every guest can feel at home and enjoy a memorable stay.</p><a class=\"btn-outline text-xs\" href=\"/about\">Our Vision</a></div><div class=\"relative\"><div class=\"aspect-[4/5] overflow-hidden\"><img src=\"/images/belmont5.jpg\" alt=\"Belmont interior detail\" class=\"w-full h-full object-cover\"/></div><div class=\"absolute -bottom-8 -left-8 bg-gold p-8 hidden lg:block\"><p class=\"font-display text-4xl text-charcoal font-light\">Est.</p><p class=\"font-display text-4xl text-charcoal font-light\">2026</p></div></div></div></section><section class=\"bg-stone/40 py-32\"><div class=\"max-w-7xl mx-auto px-6 lg:px-12\"><div class=\"flex flex-col md:flex-row md:items-end justify-between gap-6 mb-16\"><div><p class=\"section-label\">Residences</p><h2 class=\"font-display text-[clamp(2.5rem,5vw,4rem)] font-light text-charcoal leading-tight\">Find your space</h2></div><a class=\"btn-outline text-xs self-start md:self-auto\" href=\"/rooms\">All Residences</a></div><div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\"><div class=\"group bg-cream overflow-hidden cursor-pointer\"><div class=\"aspect-[4/3] overflow-hidden\"><img src=\"/images/belmont-room1.jpg\" alt=\"Comfort Suite\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\"/></div><div class=\"p-6\"><div class=\"flex justify-between items-start mb-3\"><h3 class=\"font-display text-2xl font-light text-charcoal\">Comfort Suite</h3><span class=\"text-xs text-warm-gray font-sans\">45 m²</span></div><p class=\"text-warm-gray text-sm font-sans leading-relaxed mb-4\">Elegant and efficient. Perfect for the modern professional seeking refined solo living.</p><div class=\"flex justify-between items-center pt-4 border-t border-stone\"><span class=\"text-xs tracking-widest uppercase text-warm-gray font-sans\">1 bed, 1 kitchen, 1toilet</span><span class=\"text-sm font-medium text-charcoal font-sans\">From $1,200/mo</span></div></div></div><div class=\"group bg-cream overflow-hidden cursor-pointer\"><div class=\"aspect-[4/3] overflow-hidden\"><img src=\"/images/belmont-room3.jpg\" alt=\"Executive Suite\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\"/></div><div class=\"p-6\"><div class=\"flex justify-between items-start mb-3\"><h3 class=\"font-display text-2xl font-light text-charcoal\">Executive Suite</h3><span class=\"text-xs text-warm-gray font-sans\">75 m²</span></div><p class=\"text-warm-gray text-sm font-sans leading-relaxed mb-4\">Generous proportions with a separate living space crafted for comfort and privacy.</p><div class=\"flex justify-between items-center pt-4 border-t border-stone\"><span class=\"text-xs tracking-widest uppercase text-warm-gray font-sans\">Standard room, 1 Ironing Stand, 1Washing Machine</span><span class=\"text-sm font-medium text-charcoal font-sans\">From $1,800/mo</span></div></div></div><div class=\"group bg-cream overflow-hidden cursor-pointer\"><div class=\"aspect-[4/3] overflow-hidden\"><img src=\"/images/belmont-room2.jpg\" alt=\"Classic Suite\" class=\"w-full h-full object-cover transition-transform duration-700 group-hover:scale-105\"/></div><div class=\"p-6\"><div class=\"flex justify-between items-start mb-3\"><h3 class=\"font-display text-2xl font-light text-charcoal\">Classic Suite</h3><span class=\"text-xs text-warm-gray font-sans\">130 m²</span></div><p class=\"text-warm-gray text-sm font-sans leading-relaxed mb-4\">The pinnacle of urban living — sweeping city views, curated interiors, exceptional space.</p><div class=\"flex justify-between items-center pt-4 border-t border-stone\"><span class=\"text-xs tracking-widest uppercase text-warm-gray font-sans\">1 beds · 2 baths</span><span class=\"text-sm font-medium text-charcoal font-sans\">From $3,200/mo</span></div></div></div></div></div></section><section class=\"relative py-40 overflow-hidden\"><div class=\"absolute inset-0\"><img src=\"/images/belmont4.jpg\" alt=\"Belmont exterior\" class=\"w-full h-full object-cover\"/><div class=\"absolute inset-0 bg-charcoal/70\"></div></div><div class=\"relative z-10 text-center px-6\"><p class=\"section-label text-gold-light\">Limited Availability</p><h2 class=\"font-display text-[clamp(3rem,8vw,7rem)] font-light text-cream leading-none mb-8\">Your future home<br/>is <span class=\"italic\">waiting</span></h2><a class=\"btn-primary text-xs\" href=\"/booking\">Schedule a Private Tour</a></div></section><!--$--><!--/$--></main><footer class=\"bg-charcoal text-cream\"><div class=\"max-w-7xl mx-auto px-6 lg:px-12 py-20\"><div class=\"grid grid-cols-1 md:grid-cols-4 gap-12 mb-16\"><div class=\"md:col-span-2\"><p class=\"font-display text-4xl font-light mb-6\">Belmont</p><p class=\"text-warm-gray text-sm leading-relaxed max-w-xs font-sans\">Refined urban living at the intersection of comfort and elegance. A home designed for those who expect more.</p><div class=\"flex gap-4 mt-8\"><a href=\"#\" class=\"text-xs tracking-widest uppercase text-warm-gray hover:text-gold transition-colors duration-200\">Instagram</a><a href=\"#\" class=\"text-xs tracking-widest uppercase text-warm-gray hover:text-gold transition-colors duration-200\">Twitter</a></div></div><div><p class=\"text-xs tracking-superwide uppercase text-gold mb-6\">Explore</p><ul class=\"space-y-3\"><li><a class=\"text-sm text-warm-gray hover:text-cream transition-colors font-sans\" href=\"/rooms\">Residences</a></li><li><a class=\"text-sm text-warm-gray hover:text-cream transition-colors font-sans\" href=\"/rooms#amenities\">Amenities</a></li><li><a class=\"text-sm text-warm-gray hover:text-cream transition-colors font-sans\" href=\"/about\">About Us</a></li><li><a class=\"text-sm text-warm-gray hover:text-cream transition-colors font-sans\" href=\"/booking\">Book a Tour</a></li></ul></div><div><p class=\"text-xs tracking-superwide uppercase text-gold mb-6\">Contact</p><ul class=\"space-y-3 text-sm text-warm-gray font-sans\"><li>12 Belmont Avenue</li><li>Akim Oda, Ghana</li><li class=\"pt-2\"><a href=\"tel:+233244569540\" class=\"hover:text-cream transition-colors\">+233 24 456 9540</a></li><li><a href=\"mailto:stenadu@gmail.com\" class=\"hover:text-cream transition-colors\">stenadu@gmail.com</a></li></ul></div></div><div class=\"border-t border-warm-gray/20 pt-8 flex flex-col md:flex-row justify-between gap-4 text-xs text-warm-gray font-sans\"><p>© <!-- -->